# Backups générés par le script
.config-backup-*/

# Caches / runtime du profil navigateur (régénérables, parfois sensibles)
.zen/**/cache2/
.zen/**/startupCache/
.zen/**/storage/
.zen/**/*.sqlite-wal
.zen/**/*.sqlite-shm
.zen/Crash Reports/
.zen/Pending Pings/

# Données de sites du profil navigateur (1,1 Go, régénérées)
.zen/**/storage/

# Cache de bannières du game-launcher (301 Mo, re-téléchargées par quickshell)
.config/quickshell/game-launcher/cache/

# Windsurf IDE : on ne garde que settings.json / argv.json, pas les extensions (~1 Go, re-téléchargées)
.windsurf/extensions/
.windsurf/**/cache/

# Caches divers
**/__pycache__/
*.log
*.tmp
