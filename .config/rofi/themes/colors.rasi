configuration {
    font:                           "Fira Sans 13";
    hover-select:                   true;
    me-select-entry:                "";
    me-accept-entry:                "MousePrimary";
}


* {
    background-color:       transparent;
    background:             rgba(0,0,0,0.7);
    background-transparent: #231B28;
    text-color:             #D8DEE9;
    primary:                #8A83B4;
    secondary:              #9794AB;
    urgent:                 #D8D4F4;
}
