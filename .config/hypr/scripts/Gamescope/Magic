#!/bin/bash
# Script pour lancer Magic Arena via Steam avec Hyprland optimisé
SCRIPTSDIR="$HOME/.config/hypr/scripts"
SCRIPT_NAME=$(basename "$0")

# ======= OPTIONS DE CONFIGURATION =======
GAMESCOPE_OPTIONS="False"
GAME_PERF="False"
GAME_VRR="True"
ANIMATION="False"
MANGOHUD_OPTION="False"
OPTION_AFTER=""
LANG_KEY="fr"

# ======= PARAMÈTRES GÉNÉRAUX =======
MONITOR="DP-2"
RESOLUTION="3440x1440"
REFRESH_RATE="165"
POSITION="0x0"
SCALE="1"

RES_WIDTH=3440
RES_HEIGHT=1440
FSR="True"

# ======= CONFIGURATION DYNAMIQUE =======
[[ "$FSR" == "True" ]] && FSR_MODE="-F fsr" || FSR_MODE=""

if [[ "$GAMESCOPE_OPTIONS" == "True" ]]; then
  export XKB_DEFAULT_LAYOUT=$LANG_KEY
  GAMESCOPE_SET="gamescope -f -W $RES_WIDTH -H $RES_HEIGHT -r $REFRESH_RATE $FSR_MODE --force-grab-cursor --backend sdl --"
else
  GAMESCOPE_SET=""
fi

[[ "$GAME_PERF" == "True" ]] && GAME_PERF_SET="gamemoderun" || GAME_PERF_SET=""
[[ "$MANGOHUD_OPTION" == "True" ]] && export MANGOHUD=1 || export MANGOHUD=0

# ======= GAME MODE HYPRLAND =======
enable_hyprland_gamemode() {
  if [[ "$ANIMATION" == "True" ]]; then
    hyprctl --batch "\
      keyword general:no_focus_fallback true;\
      keyword misc:focus_on_activate false;\
      keyword misc:layers_hog_keyboard_focus false;\
      keyword animations:enabled 0;\
      keyword decoration:shadow:enabled 0;\
      keyword decoration:blur:enabled 0;\
      keyword general:gaps_in 0;\
      keyword general:gaps_out 0;\
      keyword general:border_size 1;\
      keyword decoration:rounding 0"
    hyprctl keyword "windowrule opacity 1 override 1 override 1 override, ^(.*)$"
    swww kill
  fi
}

disable_hyprland_gamemode() {
  hyprctl keyword general:no_focus_fallback false
  if [[ "$ANIMATION" == "True" ]]; then
    if ! pgrep -x "swww-daemon" >/dev/null; then
      swww-daemon --format xrgb &
      sleep 0.5
      swww img "$HOME/.config/rofi/.current_wallpaper" &
      sleep 0.5
      hyprctl reload
    fi
  fi
}

# ======= GESTION WAYBAR =======
stop_waybar() {
  pgrep -x "waybar" >/dev/null && killall -q waybar && sleep 0.3
}

start_waybar() {
  pgrep -x "waybar" >/dev/null || { waybar & sleep 0.3; }
}

# ======= DÉTECTION SIMPLIFIÉE DU JEU =======
detect_game_window() {
  local game_pid=$1
  local timeout=60
  local game_class=""
  
  for i in $(seq 1 $timeout); do
    kill -0 $game_pid 2>/dev/null || return 1
    
    game_class=$(hyprctl clients -j | jq -r --arg pid "$game_pid" \
      '.[] | select(.pid == ($pid | tonumber)) | .class' 2>/dev/null)
    
    if [[ -z "$game_class" ]]; then
      game_class=$(hyprctl clients -j | jq -r \
        '.[] | select(.class | test("MTGA|steam_app")) | .class' | head -1)
    fi
    
    [[ -n "$game_class" ]] && echo "$game_class" && return 0
    sleep 1
  done
  
  return 1
}

# ======= FORCER MODE TILED =======
force_tiled_mode() {
  local game_class=$1
  
  hyprctl dispatch focuswindow "class:^($game_class)$"
  sleep 0.3
  
  local is_floating=$(hyprctl activewindow -j | jq -r '.floating')
  
  if [[ "$is_floating" == "true" ]]; then
    hyprctl dispatch togglefloating active
    sleep 0.2
    hyprctl dispatch fullscreen 2
    sleep 0.2
  else
    hyprctl dispatch fullscreen 2
  fi
}

# ======= LAUNCH THE GAME =======
enable_hyprland_gamemode

$GAME_PERF_SET $GAMESCOPE_SET "$@" $OPTION_AFTER &
GAME_PID=$!

GAME_WINDOW_CLASS=$(detect_game_window $GAME_PID)

if [[ -n "$GAME_WINDOW_CLASS" ]]; then
  if [[ "$GAME_VRR" == "True" ]]; then
    hyprctl keyword windowrulev2 "immediate, class:^($GAME_WINDOW_CLASS)$"
  fi
  
  hyprctl --batch "\
    keyword windowrulev2 'tile, class:^($GAME_WINDOW_CLASS)$';\
    keyword windowrulev2 'fullscreen, class:^($GAME_WINDOW_CLASS)$';\
    keyword windowrulev2 'workspace 1 silent, class:^($GAME_WINDOW_CLASS)$'"
  
  sleep 0.5
  force_tiled_mode "$GAME_WINDOW_CLASS"
  stop_waybar
fi

# Attendre la fermeture
while kill -0 $GAME_PID 2>/dev/null; do
  sleep 2
done

wait $GAME_PID 2>/dev/null
GAME_EXIT_CODE=$?

# ======= NETTOYAGE =======
if [[ -n "$GAME_WINDOW_CLASS" ]]; then
  hyprctl --batch "keyword windowrulev2 'unset, class:^($GAME_WINDOW_CLASS)$'"
  
  [[ "$GAME_VRR" == "True" ]] && \
    hyprctl keyword monitor "$MONITOR,${RESOLUTION}@${REFRESH_RATE},${POSITION},${SCALE},vrr,0"
fi

disable_hyprland_gamemode
sleep 1
start_waybar

exit $GAME_EXIT_CODE